# Public app
# In produzione imposta l'origine pubblica esatta, senza path o slash finale.
# Esempio: https://fleai.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Mostra Google soltanto dopo aver abilitato il provider in Supabase Auth.
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
# Codici opzionali di verifica per Google Search Console e Bing Webmaster Tools.
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Server only
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
# Luna gestisce riconoscimento e ricerca rapidi; Terra interviene come fallback e per la sintesi.
OPENAI_FAST_MODEL=gpt-5.6-luna
OPENAI_ANALYSIS_MODEL=gpt-5.6-terra
OPENAI_IMAGE_MODEL=gpt-image-2-2026-04-21

# Email, anti-spam e worker (server only)
RESEND_API_KEY=
EMAIL_FROM=Fleai <info@voxels.it>
TURNSTILE_SECRET_KEY=
INTERNAL_WORKER_SECRET=

# Supabase Edge Function secrets
# APP_URL=https://tuo-dominio-vercel.vercel.app
# INTERNAL_WORKER_SECRET=lo-stesso-valore-usato-sopra
